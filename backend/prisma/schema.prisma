// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Import {
  id            String       @id @default(cuid())
  filename      String
  totalRows     Int
  totalImported Int
  totalSkipped  Int
  createdAt     DateTime     @default(now())
  leads         Lead[]
  skippedRows   SkippedRow[]

  @@map("imports")
}

model Lead {
  id                       String   @id @default(cuid())
  importId                 String
  import                   Import   @relation(fields: [importId], references: [id], onDelete: Cascade)
  createdAt                DateTime?
  name                     String?
  email                    String?
  countryCode              String?
  mobileWithoutCountryCode String?
  company                  String?
  city                     String?
  state                    String?
  country                  String?
  leadOwner                String?
  crmStatus                String?
  crmNote                  String?
  dataSource               String?
  possessionTime           String?
  description              String?
  importedAt               DateTime @default(now())

  @@index([importId])
  @@index([email])
  @@map("leads")
}

model SkippedRow {
  id       String @id @default(cuid())
  importId String
  import   Import @relation(fields: [importId], references: [id], onDelete: Cascade)
  rawRow   Json
  reason   String

  @@index([importId])
  @@map("skipped_rows")
}
